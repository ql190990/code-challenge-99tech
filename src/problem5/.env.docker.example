# Development environment for docker-compose.yml
# Copy this file to .env.docker before running `docker compose up -d`.
#
# Inside the Docker Compose network, PostgreSQL is accessible at the
# `postgres` service hostname on its default port 5432 (not 5433, which
# is the external host mapping).

DATABASE_URL="postgresql://postgres:postgres@postgres:5432/problem5?schema=public"

# Application
PORT=3000
NODE_ENV=development

# Optional tuning — defaults are documented in README.md.
# CORS_ALLOWED_ORIGINS=*
# TRUST_PROXY=1
# REQUEST_TIMEOUT_MS=30000
# HEADERS_TIMEOUT_MS=10000
# SHUTDOWN_TIMEOUT_MS=10000
