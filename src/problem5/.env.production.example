# Production environment for docker-compose.prod.yml
# Copy this file to .env.production, fill in real values, and run:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# Every variable below is REQUIRED. docker-compose.prod.yml uses
# `${VAR:?...}` substitutions so Compose refuses to start with a clear
# error message if any variable is missing.
#
# IMPORTANT: Never commit .env.production to version control.

# --- PostgreSQL ---
# In real production, do NOT run PostgreSQL via Compose — point DATABASE_URL
# at a managed instance (RDS, Cloud SQL, etc.) and remove the postgres
# service from docker-compose.prod.yml. The variables below only apply when
# the bundled postgres service is used.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=problem5
POSTGRES_HOST_PORT=5433

# --- Application ---
# PostgreSQL connection string — MUST be updated to your managed database.
# Example for AWS RDS:
#   postgresql://admin:password@mydb.c9akciq32.us-east-1.rds.amazonaws.com:5432/problem5?schema=public
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/problem5?schema=public"
PORT=3000
NODE_ENV=production
API_HOST_PORT=3000

# CORS allowlist — comma-separated list of allowed origins or * for all.
# Examples:
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
#   CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_ORIGINS=

# Trust proxy setting — controls X-Forwarded-* header handling.
# Set to 1 for a single reverse proxy (nginx, ALB, CloudFront, etc).
# Set to 2 if you have two hops (CDN → ALB → service).
TRUST_PROXY=1

# Socket-level HTTP timeouts (milliseconds).
# REQUEST_TIMEOUT_MS controls the total socket lifetime; caps slow-body attacks.
# HEADERS_TIMEOUT_MS controls how long clients have to finish sending headers.
# Default values are usually sufficient; adjust if you see legitimate client timeouts.
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=10000

# Graceful shutdown deadline (milliseconds).
# When the service receives SIGINT/SIGTERM, it closes the HTTP server and
# waits up to this duration for in-flight requests to finish. Once expired,
# the process exits immediately. Tune to match k8s terminationGracePeriodSeconds.
SHUTDOWN_TIMEOUT_MS=10000
