# Development environment for docker-compose.yml
# Copy this file to .env.docker and run:
#   docker compose --env-file .env.docker up -d
#
# Every variable below is OPTIONAL — docker-compose.yml ships sane defaults
# (see `${VAR:-default}` substitutions) and `env_file` is marked
# `required: false`, so the stack still boots if this file is absent.
#
# Inside the Compose network, PostgreSQL is reachable at hostname
# `postgres` on its default port 5432 (not 5433, which is the host mapping).

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=problem5
# Host port mapped to the container's 5432. Change if 5433 is taken.
POSTGRES_HOST_PORT=5433

# --- Application ---
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/problem5?schema=public"
PORT=3000
NODE_ENV=development
# Host port mapped to the API container's PORT.
API_HOST_PORT=3000
# Host port mapped to the Node inspector (9229 inside the container).
DEBUG_HOST_PORT=9229

# --- Optional tuning (defaults documented in README.md) ---
# CORS_ALLOWED_ORIGINS=*
# TRUST_PROXY=1
# REQUEST_TIMEOUT_MS=30000
# HEADERS_TIMEOUT_MS=10000
# SHUTDOWN_TIMEOUT_MS=10000
