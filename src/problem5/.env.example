# PostgreSQL connection string. Matches the credentials in docker-compose.yml.
# The test suite uses a sibling database `problem5_test` so tests never touch
# the development dataset.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/problem5?schema=public"

# Application
PORT=3000
NODE_ENV=development

# Optional tuning — defaults are documented in README.md.
# CORS_ALLOWED_ORIGINS=*
# TRUST_PROXY=1
# REQUEST_TIMEOUT_MS=30000
# HEADERS_TIMEOUT_MS=10000
# SHUTDOWN_TIMEOUT_MS=10000
